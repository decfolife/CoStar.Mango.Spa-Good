{
  "name": "crem-prototype",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/crem-prototype/src",
  "prefix": "mango",
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "dependsOn": [],
      "options": {
        "outputPath": "dist/apps/crem-prototype",
        "index": "apps/crem-prototype/src/index.html",
        "main": "apps/crem-prototype/src/main.ts",
        "polyfills": "apps/crem-prototype/src/polyfills.ts",
        "tsConfig": "apps/crem-prototype/tsconfig.app.json",
        "stylePreprocessorOptions": {
          "includePaths": [
            "libs/ui-shared",
            "apps/mango",
            "apps/mango/src/assets/styles"
          ]
        },
        "assets": [
          "apps/crem-prototype/src/favicon.ico",
          "apps/crem-prototype/src/assets"
        ],
        "styles": ["apps/crem-prototype/src/styles.scss"],
        "scripts": [],
        "vendorChunk": true,
        "extractLicenses": false,
        "buildOptimizer": false,
        "sourceMap": true,
        "optimization": false,
        "namedChunks": true,
        "aot": true
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/crem-prototype/src/environments/environment.ts",
              "with": "apps/crem-prototype/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true,
          "budgets": []
        }
      }
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "browserTarget": "crem-prototype:build"
      },
      "configurations": {
        "production": {
          "browserTarget": "crem-prototype:build:production"
        }
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "crem-prototype:build"
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": [
          "apps/crem-prototype/src/**/*.ts",
          "apps/crem-prototype/src/**/*.html"
        ]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/crem-prototype"],
      "options": {
        "jestConfig": "apps/crem-prototype/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
