{
  "name": "mango-crem-features-micro-components",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/mango-crem-features/micro-components/src",
  "prefix": "mango",
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "dependsOn": [],
      "options": {
        "outputPath": "dist/apps/mango-crem-features/micro-components",
        "index": "apps/mango-crem-features/micro-components/src/index.html",
        "main": "apps/mango-crem-features/micro-components/src/main.ts",
        "polyfills": "apps/mango-crem-features/micro-components/src/polyfills.ts",
        "tsConfig": "apps/mango-crem-features/micro-components/tsconfig.app.json",
        "aot": true,
        "stylePreprocessorOptions": {
          "includePaths": [
            "libs/ui-shared",
            "apps/mango",
            "apps/mango/src/assets/styles",
            "libs/ui-shared/common/src"
          ]
        },
        "assets": [
          "apps/mango-crem-features/micro-components/src/favicon.ico",
          "apps/mango-crem-features/micro-components/src/assets"
        ],
        "styles": [
          "node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
          "node_modules/@angular/material/_theming.scss",
          "node_modules/devextreme/dist/css/dx.light.css",
          "apps/mango-crem-features/micro-components/src/styles.scss",
          "libs/ui-shared/common/src/styles/_index.scss"
        ],
        "scripts": []
      },
      "configurations": {
        "dev": {
          "optimization": {
            "scripts": true,
            "styles": {
              "minify": true,
              "inlineCritical": false
            },
            "fonts": false
          },
          "outputHashing": "none",
          "sourceMap": true,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true,
          "fileReplacements": [
            {
              "replace": "apps/mango/src/environments/environment.local.ts",
              "with": "apps/mango-crem-features/micro-components/src/environments/environment.dev.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "20mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "1mb"
            }
          ]
        },
        "test": {
          "optimization": {
            "scripts": true,
            "styles": {
              "minify": true,
              "inlineCritical": false
            },
            "fonts": false
          },
          "outputHashing": "none",
          "sourceMap": false,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true,
          "fileReplacements": [
            {
              "replace": "apps/mango/src/environments/environment.local.ts",
              "with": "apps/mango-crem-features/micro-components/src/environments/environment.test.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "20mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "1mb"
            }
          ]
        },
        "ops": {
          "optimization": {
            "scripts": true,
            "styles": {
              "minify": true,
              "inlineCritical": false
            },
            "fonts": false
          },
          "outputHashing": "none",
          "sourceMap": false,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true,
          "fileReplacements": [
            {
              "replace": "apps/mango/src/environments/environment.local.ts",
              "with": "apps/mango-crem-features/micro-components/src/environments/environment.ops.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "20mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "1mb"
            }
          ]
        },
        "stage": {
          "optimization": {
            "scripts": true,
            "styles": {
              "minify": true,
              "inlineCritical": false
            },
            "fonts": false
          },
          "outputHashing": "none",
          "sourceMap": false,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true,
          "fileReplacements": [
            {
              "replace": "apps/mango/src/environments/environment.local.ts",
              "with": "apps/mango-crem-features/micro-components/src/environments/environment.stage.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "20mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "1mb"
            }
          ]
        },
        "prod": {
          "optimization": {
            "scripts": true,
            "styles": {
              "minify": true,
              "inlineCritical": false
            },
            "fonts": false
          },
          "outputHashing": "none",
          "sourceMap": false,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true,
          "fileReplacements": [
            {
              "replace": "apps/mango/src/environments/environment.local.ts",
              "with": "apps/mango-crem-features/micro-components/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "20mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "1mb"
            }
          ]
        }
      }
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "browserTarget": "mango-crem-features-micro-components:build"
      },
      "configurations": {
        "production": {
          "browserTarget": "mango-crem-features-micro-components:build:production"
        }
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "mango-crem-features-micro-components:build"
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "options": {
        "lintFilePatterns": [
          "apps/mango-crem-features/micro-components/src/**/*.ts",
          "apps/mango-crem-features/micro-components/src/**/*.html"
        ]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/apps/mango-crem-features/micro-components"
      ],
      "options": {
        "jestConfig": "apps/mango-crem-features/micro-components/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
