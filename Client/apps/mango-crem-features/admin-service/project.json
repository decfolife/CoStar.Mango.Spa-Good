{
  "name": "mango-crem-features-admin-service",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/mango-crem-features/admin-service/src",
  "prefix": "mango",
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "dependsOn": [],
      "options": {
        "outputPath": "dist/apps/mango-crem-features/admin-service",
        "index": "apps/mango-crem-features/admin-service/src/index.html",
        "main": "apps/mango-crem-features/admin-service/src/main.ts",
        "polyfills": "apps/mango-crem-features/admin-service/src/polyfills.ts",
        "tsConfig": "apps/mango-crem-features/admin-service/tsconfig.app.json",
        "assets": [
          "apps/mango-crem-features/admin-service/src/favicon.ico",
          "apps/mango-crem-features/admin-service/src/assets"
        ],
        "styles": [
          "node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
          "node_modules/devextreme/dist/css/dx.light.css",
          "node_modules/devexpress-gantt/dist/dx-gantt.css",
          "node_modules/@angular/material/_theming.scss",
          "apps/mango-crem-features/admin-service/src/assets/styles/my-devextreme.scss",
          "apps/mango-crem-features/admin-service/src/assets/dx.generic.overlay-theme.scss",
          "apps/mango-crem-features/admin-service/src/styles.scss"
        ],
        "scripts": [],
        "vendorChunk": true,
        "extractLicenses": false,
        "buildOptimizer": false,
        "sourceMap": true,
        "optimization": false,
        "namedChunks": true,
        "aot": true
      },
      "configurations": {
        "dev": {
          "optimization": true,
          "outputHashing": "none",
          "sourceMap": false,
          "namedChunks": false,
          "commonChunk": false,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true,
          "fileReplacements": [
            {
              "replace": "apps/mango/src/environments/environment.local.ts",
              "with": "apps/mango-crem-features/admin-service/src/environments/environment.dev.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "10mb",
              "maximumError": "20mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "1mb"
            }
          ]
        },
        "test": {
          "optimization": true,
          "outputHashing": "none",
          "sourceMap": false,
          "namedChunks": false,
          "commonChunk": false,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true,
          "fileReplacements": [
            {
              "replace": "apps/mango/src/environments/environment.local.ts",
              "with": "apps/mango-crem-features/admin-service/src/environments/environment.test.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "10mb",
              "maximumError": "20mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "1mb"
            }
          ]
        },
        "ops": {
          "optimization": true,
          "outputHashing": "none",
          "sourceMap": false,
          "namedChunks": false,
          "commonChunk": false,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true,
          "fileReplacements": [
            {
              "replace": "apps/mango/src/environments/environment.local.ts",
              "with": "apps/mango-crem-features/admin-service/src/environments/environment.ops.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "10mb",
              "maximumError": "20mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "100kb"
            }
          ]
        },
        "stage": {
          "optimization": true,
          "outputHashing": "none",
          "sourceMap": false,
          "namedChunks": false,
          "commonChunk": false,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true,
          "fileReplacements": [
            {
              "replace": "apps/mango/src/environments/environment.local.ts",
              "with": "apps/mango-crem-features/admin-service/src/environments/environment.stage.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "10mb",
              "maximumError": "20mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "100kb"
            }
          ]
        },
        "prod": {
          "fileReplacements": [
            {
              "replace": "apps/mango/src/environments/environment.local.ts",
              "with": "apps/mango-crem-features/admin-service/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "commonChunk": false,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true,
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "10mb",
              "maximumError": "20mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "10kb"
            }
          ]
        }
      }
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "browserTarget": "mango-crem-features-admin-service:build"
      },
      "configurations": {
        "production": {
          "browserTarget": "mango-crem-features-admin-service:build:production"
        }
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "mango-crem-features-admin-service:build"
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/apps/mango-crem-features/admin-service"
      ],
      "options": {
        "jestConfig": "apps/mango-crem-features/admin-service/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
