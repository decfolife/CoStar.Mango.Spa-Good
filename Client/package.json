{
  "name": "mango",
  "version": "1.0.1",
  "license": "MIT",
  "scripts": {
    "ng": "nx",
    "postinstall": "node ./decorate-angular-cli.js",
    "nx": "node --max_old_space_size=8192 ./node_modules/nx/bin/nx.js",
    "start": "node --max_old_space_size=8192 ./node_modules/nx/bin/nx.js serve mango --configuration=fast",
    "start:local": "node --max_old_space_size=8192 ./node_modules/nx/bin/nx.js serve mango --configuration=local",
    "start:fast": "node --max_old_space_size=8192 ./node_modules/nx/bin/nx.js serve mango --configuration=fast",
    "start:test": "node --max_old_space_size=8192 ./node_modules/nx/bin/nx.js serve mango --configuration=test",
    "start:test-local": "node --max_old_space_size=8192 ./node_modules/nx/bin/nx.js serve mango --configuration=testLocal",
    "start:test-fast": "node --max_old_space_size=8192 ./node_modules/nx/bin/nx.js serve mango --configuration=testFast",
    "clean": "npx rimraf -v ./node_modules/ dist/ .angular/ .nx/",
    "prepare": "cd .. && husky .husky && husky install",
    "lint": "nx workspace-lint && ng lint",
    "e2e": "ng e2e",
    "test:mango": "nx test",
    "test:mango:watch": "nx test --watch",
    "test:features": "npx jest --config=jest.features.config.ts --testPathPattern=apps/mango-crem-features/.*/.*",
    "test:features:watch": "npx jest --watch --config=jest.features.config.ts --testPathPattern=apps/mango-crem-features/.*/.*",
    "test:ui-shared": "nx test ui-shared",
    "test:ui-shared:watch": "nx test --watch ui-shared",
    "test:central-auth": "ng test mango-crem-features-central-auth",
    "test:central-auth:watch": "ng test --watch mango-crem-features-central-auth",
    "affected:apps": "nx affected:apps",
    "affected:libs": "nx affected:libs",
    "affected:build": "nx affected:build",
    "affected:e2e": "nx affected:e2e",
    "affected:test": "nx affected:test",
    "affected:lint": "nx affected:lint",
    "affected:dep-graph": "nx affected:dep-graph",
    "affected": "nx affected",
    "format": "nx format:write",
    "format:write": "nx format:write",
    "format:check": "nx format:check",
    "update": "nx migrate latest",
    "workspace-generator": "nx workspace-generator",
    "dep-graph": "nx dep-graph",
    "help": "nx help",
    "compodoc": "npx compodoc -p libs/ui-shared/lib-ui-elements/tsconfig.lib.json -e html --theme material --output dist/storybook/ui-shared-storybook-host/compodocs -n Shared-Library-Docs --customLogo apps/mango/src/assets/images/logos/CoStar.svg --customFavicon apps/mango/src/favicon.ico",
    "build:mango": "node --max_old_space_size=8192 ./node_modules/@angular/cli/bin/ng build mango --configuration=dev",
    "build:local:mango": "ng build",
    "build:dev:mango": "node --max_old_space_size=8192 ./node_modules/@angular/cli/bin/ng build mango --configuration=dev",
    "build:test:mango": "node --max_old_space_size=8192 ./node_modules/@angular/cli/bin/ng build mango --configuration=test",
    "build:ops:mango": "node --max_old_space_size=8192 ./node_modules/@angular/cli/bin/ng build mango --configuration=ops",
    "build:stage:mango": "node --max_old_space_size=8192 ./node_modules/@angular/cli/bin/ng build mango --configuration=stage",
    "build:prod:mango": "node --max_old_space_size=8192 ./node_modules/@angular/cli/bin/ng build mango --configuration=prod",
    "build:dr:mango": "node --max_old_space_size=8192 ./node_modules/@angular/cli/bin/ng build mango --configuration=dr",
    "build:dev:microcomponent-central-auth": "ng build mango-crem-features-central-auth --configuration=dev && node build-element.js central-auth",
    "build:test:microcomponent-central-auth": "ng build mango-crem-features-central-auth --configuration=test && node build-element.js central-auth",
    "build:ops:microcomponent-central-auth": "ng build mango-crem-features-central-auth --configuration=ops && node build-element.js central-auth",
    "build:stage:microcomponent-central-auth": "ng build mango-crem-features-central-auth --configuration=stage && node build-element.js central-auth",
    "build:prod:microcomponent-central-auth": "ng build mango-crem-features-central-auth --configuration=prod && node build-element.js central-auth",
    "build:dr:microcomponent-central-auth": "ng build mango-crem-features-central-auth --configuration=dr && node build-element.js central-auth"
  },
  "private": true,
  "lint-staged": {
    "**/*.{scss,js,ts,html,json}": [
      "prettier --write"
    ]
