{
  "name": "forms-shared",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/forms-shared/src",
  "prefix": "mango",
  "targets": {
    "lint": {
      "executor": "@nx/linter:eslint",
      "options": {
        "lintFilePatterns": [
          "libs/forms-shared/src/**/*.ts",
          "libs/forms-shared/src/**/*.html"
        ]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/forms-shared"],
      "options": {
        "jestConfig": "libs/forms-shared/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
