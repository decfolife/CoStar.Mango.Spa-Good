{
  "extends": ["../../../.eslintrc.js"],
  "ignorePatterns": ["!**/*", "*.spec.ts"],
  "overrides": [
    {
      "files": ["*.ts"],
      "extends": [
        "plugin:@nx/angular",
        "plugin:@angular-eslint/template/process-inline-templates"
      ],
      "parserOptions": {
        "project": ["libs/ui-shared/lib-external-libraries/tsconfig.*?.json"]
      },
      "rules": {
        "@angular-eslint/no-output-native": "warn", // TODO: Check whether to turn rule off or fix.
        "@angular-eslint/no-output-on-prefix": "warn", // TODO: Check whether to turn rule off or fix.
        "@angular-eslint/no-host-metadata-property": "warn",
        "@typescript-eslint/no-empty-function": "warn",
        "@typescript-eslint/no-explicit-any": "warn",
        "@angular-eslint/directive-selector": [
          "error",
          {
            "type": "attribute",
            "style": "camelCase"
          }
        ],
        "@angular-eslint/component-selector": [
          "error",
          {
            "type": "element",
            "prefix": "crem",
            "style": "kebab-case"
          }
        ]
      }
    },
    {
      "files": ["*.html"],
      "extends": ["plugin:@nx/angular-template"],
      "rules": {}
    }
  ]
}
