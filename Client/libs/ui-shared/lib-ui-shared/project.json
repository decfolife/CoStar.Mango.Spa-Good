{
  "name": "ui-shared-lib-ui-shared",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/ui-shared/lib-ui-shared/src",
  "prefix": "mango",
  "targets": {
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": [
          "libs/ui-shared/lib-ui-shared/src/**/*.ts",
          "libs/ui-shared/lib-ui-shared/src/**/*.html"
        ]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/ui-shared/lib-ui-shared"],
      "options": {
        "jestConfig": "libs/ui-shared/lib-ui-shared/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/ui-shared/lib-ui-shared/.storybook",
        "browserTarget": "ui-shared-lib-ui-shared:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/ui-shared-lib-ui-shared",
        "configDir": "libs/ui-shared/lib-ui-shared/.storybook",
        "browserTarget": "ui-shared-lib-ui-shared:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    }
  },
  "tags": [],
  "implicitDependencies": [
    "ui-shared-lib-ui-elements",
    "ui-shared-common"
  ]
}
