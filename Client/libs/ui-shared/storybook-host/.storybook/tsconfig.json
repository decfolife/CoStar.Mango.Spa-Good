{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
  },
  "exclude": [
    "../**/*.spec.ts",
    "../../**/*.spec.ts",
    "../../cosmos",
  ],
  "include": [
    /**
     * Libraries and components, tokens and documentation below
    */
    // General Storybook Documentation
    "../docs/**/*.stories.mdx",
    // Tokens
    "../../common/**/*.stories.ts",
    "../../common/**/*.stories.mdx",
    // Add ui-shared folders below, add same folders on main.js as well
    "../../lib-ui-elements/**/*.stories.ts",
    "../../lib-ui-elements/**/*.component.ts",
    "../../lib-ui-elements/**/*.stories.mdx",
    "*.js",
    "preview.ts",
    "main.ts",
  ]
}