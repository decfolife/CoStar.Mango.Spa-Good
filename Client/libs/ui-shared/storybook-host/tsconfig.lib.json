{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "target": "es2015",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": [],
    "lib": ["dom", "es2018"]
  },
  "exclude": [
    "../cosmos",
    "src/test-setup.ts",
    "src/**/*.spec.ts",
    "jest.config.ts",
    "src/**/*.test.ts",
    "**/*.stories.ts",
    "**/*.stories.js"
  ],
  "include": [
    "*.js",
    "src/**/*.ts",
    "../**/src/**/*.stories.ts",
    "../**/src/**/*.component.ts",
  ]
}
