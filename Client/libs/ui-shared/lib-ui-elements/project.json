{
  "name": "ui-shared-lib-ui-elements",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/ui-shared/lib-ui-elements/src",
  "prefix": "mango",
  "targets": {
    "lint": {
      "executor": "@nx/linter:eslint",
      "options": {
        "lintFilePatterns": [
          "libs/ui-shared/lib-ui-elements/src/**/*.ts",
          "libs/ui-shared/lib-ui-elements/src/**/*.html"
        ]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/ui-shared/lib-ui-elements"],
      "options": {
        "jestConfig": "libs/ui-shared/lib-ui-elements/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/ui-shared/lib-ui-elements/.storybook",
        "browserTarget": "ui-shared-lib-ui-elements:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/ui-shared-lib-ui-elements",
        "configDir": "libs/ui-shared/lib-ui-elements/.storybook",
        "browserTarget": "ui-shared-lib-ui-elements:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    }
  },
  "tags": [],
  "implicitDependencies": ["ui-shared-common"]
}
