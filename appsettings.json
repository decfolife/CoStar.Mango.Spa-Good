{
  "AllowedHosts": "*",
  "AppSettings": {
    "ApplicationName": "MangoSPA.BFF",
    "Environment": "",
    "IsInKubernetes": false,
    "EnableCaching": true,
    "UseInMemoryCaching": true
  },
  "ServicesUrls": {
    "IdentityApiUrl": ""
  },
  "Auth": {
    "CookieExpireInMinutes": 1440, // 24 hours
    "CorsOrigins": [
      "https://*.costarremanager.com",
      "https://*.corp.virtualpremise.com",
      "https://*.corp.virtualpremise.com:30443",
      "http://*.corp.virtualpremise.com",
      "http://*.corp.virtualpremise.com:30080"
    ]
  },
  "Redis": {
    "Connection": "",
    "Port": 6379,
    "Instance": "",
    "Token": "",
    "UseSSL": false
  },
  "RateLimit": {
    "WindowInSeconds": 20,
    "PermitLimit": 100
  },
  // Route all incoming requests to nginx (the entry point to the microservices that live in k8s)
  "ReverseProxy": {
    "Routes": {
      "route1": {
        "ClusterId": "nginx-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "{**catch-all}"
        },
        "Transforms": [
          {
            // authentication cookie is not needed when calling the microservices. Only the JWT
            "RequestHeaderRemove": "Cookie"
          }
        ]
      },
      // Rate limiting for POST/PUT/DELETE/PATCH
      "route-post": {
        "ClusterId": "nginx-service",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed-by-user-and-path",
        "Match": {
          "Path": "{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE", "PATCH" ]
        },
        "Transforms": [
          {
            // authentication cookie is not needed when calling the microservices. Only the JWT
            "RequestHeaderRemove": "Cookie"
          }
        ]
      }
    },
    "Clusters": {
      "nginx-service": {
        "Destinations": {
          "destination1": {
            "Address": "https://api.dev.corp.virtualpremise.com:30443/"
          }
        }
      }
    }
  }
}
