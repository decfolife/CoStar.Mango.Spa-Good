{
  "AllowedHosts": "*",
  "AppSettings": {
    "ApplicationName": "MangoSPA.WebServer",
    "Environment": "",
    "IsInKubernetes": false,
    "CacheType": "Redis",
    "EnableCaching": false,
    "RedisDefaultConnection": ""
  },
  "ServicesUrls": {
    "IdentityApiUrl": ""
  },
  "Auth": {
    "CookieExpireInMinutes": 480 // 8 hours
  },
  // Route all incoming requests to nginx (the entry point to the microservices that live in k8s)
  "ReverseProxy": {
    "Routes": {
      "route1": {
        "ClusterId": "nginx-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "{**catch-all}"
        },
        "Transforms": [
          {
            // authentication cookie is not needed when calling the microservices. Only the JWT
            "RequestHeaderRemove": "Cookie"
          }
        ]
      }
    },
    "Clusters": {
      "nginx-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://api.dev.corp.virtualpremise.com:30080/"
          }
        }
      }
    }
  }
}
